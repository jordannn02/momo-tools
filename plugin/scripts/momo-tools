    "capability",
    "level",
    "status",
    "checked_at",
    "command",
    "evidence_ref",
    "risk_boundary",
}
VERIFIED_WORKING_FRESHNESS_FIELDS = {"checked_at", "valid_until"}

RISK_HINTS = {
    "write": [
