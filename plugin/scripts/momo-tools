    "write": [
        "do not save",
        "don't save",
        "no save",
        "do not write",
        "don't write",
        "no write",
        "read only",
        "read-only",
    ],
    "external-network": [
        "do not browse",
        "don't browse",
        "no web",
        "offline only",
    ],
}

ACTION_HINTS = {
    "persist": ["save", "remember", "capture", "write note", "store"],
    "send": ["send", "reply", "email", "message"],
    "delete": ["delete", "archive", "remove", "trash"],
    "external-call": ["latest", "current", "browse", "website", "web", "online"],
    "private-read": ["email", "inbox", "customer", "client", "account", "private"],
    "credential-use": ["api key", "secret", "token", "credential", "password"],
}


def parse_scalar(value: str):
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def load_simple_yaml_index(path: Path):
    capabilities = []
    current = None
    current_list_key = None
    for line_no, raw in enumerate(path.read_text(encoding="utf-8").splitlines(), 1):
        if not raw.strip() or raw.lstrip().startswith("#"):
            continue
        indent = len(raw) - len(raw.lstrip(" "))
        stripped = raw.strip()
        if indent == 0 and stripped.startswith("- "):
            current = {}
            capabilities.append(current)
            current_list_key = None
            item = stripped[2:].strip()
            if item:
                if ":" not in item:
                    raise SystemExit(f"invalid YAML index {path}:{line_no}: expected key: value")
                key, value = item.split(":", 1)
                current[key.strip()] = parse_scalar(value)
            continue
        if current is None:
            raise SystemExit(f"invalid YAML index {path}:{line_no}: expected top-level list item")
        if stripped.startswith("- "):
            if current_list_key is None:
                raise SystemExit(f"invalid YAML index {path}:{line_no}: list item without key")
            current[current_list_key].append(parse_scalar(stripped[2:]))
            continue
        if ":" not in stripped:
            raise SystemExit(f"invalid YAML index {path}:{line_no}: expected key: value")
        key, value = stripped.split(":", 1)
        key = key.strip()
        value = value.strip()
        if value:
            current[key] = parse_scalar(value)
            current_list_key = None
        else:
            current[key] = []
            current_list_key = key
    return capabilities


def load_index(path: Path):
    try:
        if path.suffix.lower() in YAML_EXTENSIONS:
            data = load_simple_yaml_index(path)
        else:
            data = json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        raise SystemExit(f"index not found: {path}")
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid JSON index {path}: {exc}")
    if not isinstance(data, list):
        raise SystemExit("index must be an array/list of capabilities")
    return data


def normalize_words(text: str):
    return re.findall(r"[a-z0-9][a-z0-9_-]*", text.lower())


def contains_phrase(text: str, phrase: str):
    return phrase.lower() in text.lower()


def validation_errors(capabilities):
    errors = []
    names = Counter()
    for idx, cap in enumerate(capabilities):
        if not isinstance(cap, dict):
            errors.append(f"<row {idx}>: capability must be an object")
            continue
        name = cap.get("name", f"<row {idx}>")
        names[name] += 1
        missing = sorted(REQUIRED_FIELDS - set(cap))
        if missing:
            errors.append(f"{name}: missing fields {', '.join(missing)}")
        if cap.get("verification_level") not in VERIFICATION_LEVELS:
            errors.append(f"{name}: invalid verification_level {cap.get('verification_level')!r}")
        for field in ("trigger", "risk", "known_caveats", "canonical_for"):
            if field in cap and not isinstance(cap[field], list):
                errors.append(f"{name}: {field} must be a list")
    for name, count in names.items():
        if count > 1:
            errors.append(f"{name}: duplicate capability name ({count})")
    return errors


def infer_gates(prompt: str):
    prompt_l = prompt.lower()
    gates = set()
    for risk, hints in RISK_HINTS.items():
        if any(hint in prompt_l for hint in hints):
            gates.add(risk)
    for risk, negations in NEGATIONS.items():
        if any(neg in prompt_l for neg in negations):
            gates.add(risk)
    return sorted(gates)


def infer_actions(prompt: str):
    prompt_l = prompt.lower()
    actions = set()
    for action, hints in ACTION_HINTS.items():
        if any(hint in prompt_l for hint in hints):
            actions.add(action)
    return sorted(actions)


def score_capability(cap, prompt: str):
    prompt_l = prompt.lower()
    prompt_words = set(normalize_words(prompt))
    score = 0
    reasons = []

    for phrase in cap.get("trigger", []):
        phrase_l = str(phrase).lower()
        if phrase_l in prompt_l:
            score += 5
            reasons.append(f"trigger:{phrase}")
        else:
            phrase_words = set(normalize_words(phrase_l))
            overlap = prompt_words & phrase_words
            if overlap:
                score += len(overlap)
                reasons.append(f"keyword:{'/'.join(sorted(overlap))}")

    for label in cap.get("canonical_for", []):
        label_words = set(normalize_words(str(label)))
        overlap = prompt_words & label_words
        if overlap:
            score += 2 * len(overlap)
            reasons.append(f"canonical:{'/'.join(sorted(overlap))}")

    name_words = set(normalize_words(cap.get("name", "")))
    overlap = prompt_words & name_words
    if overlap:
        score += 2 * len(overlap)
        reasons.append(f"name:{'/'.join(sorted(overlap))}")

    if score > 0 and cap.get("verification_level") == "verified-working":
        score += 1

    return score, reasons


def route(capabilities, prompt: str, limit: int):
    gates = infer_gates(prompt)
    actions = infer_actions(prompt)
    prompt_l = prompt.lower()
    blocked_risks = {
        risk
        for risk, negations in NEGATIONS.items()
        if any(neg in prompt_l for neg in negations)
    }

    ranked = []
    for cap in capabilities:
        score, reasons = score_capability(cap, prompt)
        if score <= 0:
            continue
        risk_set = set(cap.get("risk", []))
        blocked = sorted(risk_set & blocked_risks)
        ranked.append(
            {
                "name": cap["name"],
                "score": score,
                "verification_level": cap.get("verification_level"),
                "risk": cap.get("risk", []),
                "blocked_by_prompt": blocked,
                "reasons": reasons[:5],
                "path_or_tool": cap.get("path_or_tool"),
                "workflow_shape": cap.get("workflow_shape"),
            }
        )
    ranked.sort(key=lambda item: (bool(item["blocked_by_prompt"]), -item["score"], item["name"]))
    return {"prompt": prompt, "gates": gates, "actions": actions, "matches": ranked[:limit]}


def print_json(data):
    print(json.dumps(data, indent=2, ensure_ascii=False))


def cmd_validate(args):
    capabilities = load_index(args.index)
    errors = validation_errors(capabilities)
    if errors:
        print_json({"ok": False, "errors": errors})
        return 1
    print_json({"ok": True, "capability_count": len(capabilities)})
    return 0


def cmd_dashboard(args):
    capabilities = load_index(args.index)
    errors = validation_errors(capabilities)
    if errors:
        print_json(
            {
                "read_only": True,
                "capability_count": len(capabilities),
                "verification_levels": {},
                "risks": {},
                "validation_errors": len(errors),
                "errors": errors,
            }
        )
        return 1
    levels = Counter(cap.get("verification_level", "missing") for cap in capabilities)
    risks = Counter(risk for cap in capabilities for risk in cap.get("risk", []))
    print_json(
        {
            "read_only": True,
            "capability_count": len(capabilities),
            "verification_levels": dict(sorted(levels.items())),
            "risks": dict(sorted(risks.items())),
            "validation_errors": len(errors),
            "errors": errors,
        }
    )
    return 1 if errors else 0


def cmd_list(args):
    capabilities = load_index(args.index)
    for cap in capabilities:
        risks = ",".join(cap.get("risk", []))
        print(f"{cap['name']}\t{cap['type']}\t{cap['verification_level']}\t{risks}")
    return 0


def cmd_route(args):
    capabilities = load_index(args.index)
    result = route(capabilities, args.prompt, args.limit)
    print_json(result)
    return 0


def load_cases(path: Path):
    try:
        cases = json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        raise SystemExit(f"cases not found: {path}")
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid route cases {path}: {exc}")
    if not isinstance(cases, list) or not cases:
        raise SystemExit(f"route cases must be a non-empty array: {path}")
    seen_ids = set()
    for index_number, case in enumerate(cases, 1):
        if not isinstance(case, dict):
            raise SystemExit(f"route case {index_number} must be an object: {path}")
        case_id = case.get("id")
        prompt = case.get("prompt")
        if not isinstance(case_id, str) or not case_id.strip():
            raise SystemExit(f"route case {index_number} has an invalid id: {path}")
        if case_id in seen_ids:
            raise SystemExit(f"duplicate route case id {case_id!r}: {path}")
        seen_ids.add(case_id)
        if not isinstance(prompt, str) or not prompt.strip():
            raise SystemExit(f"route case {case_id!r} has an invalid prompt: {path}")
        for field in ("expected", "forbidden", "must_gate"):
            value = case.get(field, [])
            if not isinstance(value, list) or not all(
                isinstance(item, str) for item in value
            ):
                raise SystemExit(
                    f"route case {case_id!r} field {field} must be a string array: {path}"
                )
    return cases


def evaluate_cases(capabilities, cases):
    results = []
    ok = True
    for case in cases:
        result = route(capabilities, case["prompt"], 8)
        names = [match["name"] for match in result["matches"] if not match["blocked_by_prompt"]]
        all_names = [match["name"] for match in result["matches"]]
        gates = set(result["gates"])
        expected_missing = [name for name in case.get("expected", []) if name not in all_names]
        forbidden_present = [name for name in case.get("forbidden", []) if name in names]
        gates_missing = [gate for gate in case.get("must_gate", []) if gate not in gates]
        passed = not expected_missing and not forbidden_present and not gates_missing
        ok = ok and passed
        results.append(
            {
                "id": case["id"],
                "passed": passed,
                "expected_missing": expected_missing,
                "forbidden_present": forbidden_present,
                "gates_missing": gates_missing,
                "top_matches": all_names[:5],
                "gates": sorted(gates),
            }
        )
    return ok, results


def cmd_audit(args):
    capabilities = load_index(args.index)
    cases = load_cases(args.cases)
    ok, results = evaluate_cases(capabilities, cases)
    print_json({"ok": ok, "case_count": len(cases), "results": results})
    return 0 if ok else 1


def cmd_benchmark(args):
    capabilities = load_index(args.index)
    cases = load_cases(args.cases)
    ok, results = evaluate_cases(capabilities, cases)
    passed = sum(1 for result in results if result["passed"])
    print_json(
        {
            "ok": ok,
            "case_count": len(cases),
            "passed": passed,
            "pass_rate": round(passed / len(cases), 4) if cases else 0,
            "results": results,
        }
    )
    return 0 if ok else 1


def cmd_pressure(args):
    capabilities = load_index(args.index)
    cases = [
        {
            "id": "no_save_overrides_memory",
            "prompt": "Summarize the document and remember the conclusions, but do not save or write anything.",
            "expected": ["document-reader"],
            "forbidden": ["memory-capture"],
            "must_gate": ["write"],
        },
        {
            "id": "no_web_blocks_latest",
            "prompt": "Give me the latest official release notes, but do not browse the web.",
            "expected": ["browser-research"],
            "forbidden": [],
            "must_gate": ["external-network"],
        },
        {
            "id": "private_email_requires_gates",
            "prompt": "Search my inbox for a client thread and prepare a reply.",
            "expected": ["email-triage"],
            "forbidden": [],
            "must_gate": ["private-data", "external-network", "write"],
        },
    ]
    ok, results = evaluate_cases(capabilities, cases)
    print_json({"ok": ok, "case_count": len(cases), "results": results})
    return 0 if ok else 1


def load_evidence(path: Path):
    records = []
    errors = []
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except FileNotFoundError:
        raise SystemExit(f"evidence not found: {path}")
    for line_no, line in enumerate(lines, 1):
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        try:
            record = json.loads(line)
        except json.JSONDecodeError as exc:
            errors.append(f"{path}:{line_no}: invalid JSONL record: {exc}")
            continue
        if not isinstance(record, dict):
            errors.append(f"{path}:{line_no}: record must be an object")
            continue
        missing = sorted(EVIDENCE_REQUIRED_FIELDS - set(record))
        if missing:
            errors.append(f"{path}:{line_no}: missing fields {', '.join(missing)}")
        if record.get("level") not in VERIFICATION_LEVELS:
            errors.append(f"{path}:{line_no}: invalid level {record.get('level')!r}")
        records.append(record)
    return records, errors


def parse_aware_timestamp(value, label):
    if not isinstance(value, str):
        return None, f"{label} must be an ISO 8601 timestamp with timezone"
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None, f"{label} is not a valid ISO 8601 timestamp"
    if parsed.tzinfo is None or parsed.utcoffset() is None:
        return None, f"{label} must include a timezone offset"
    return parsed, None


def evidence_as_of(value):
    if value is None:
        return datetime.now(timezone.utc)
    parsed, error = parse_aware_timestamp(value, "--as-of")
    if error:
        raise SystemExit(error)
    return parsed


def assess_evidence(records, as_of):
    assessed = []
    for record in records:
        raw_level = record.get("level", "missing")
        result = {
            "capability": record.get("capability", "missing"),
            "raw_level": raw_level,
            "effective_level": raw_level,
            "freshness": "not-applicable",
            "errors": [],
        }
        if raw_level != "verified-working":
            assessed.append(result)
            continue

        if record.get("status") != "passed":
            result["errors"].append("verified-working status must be passed")

        missing = sorted(VERIFIED_WORKING_FRESHNESS_FIELDS - set(record))
        if missing:
            result["errors"].append(f"missing fields {', '.join(missing)}")
        checked_at, checked_error = parse_aware_timestamp(record.get("checked_at"), "checked_at")
        valid_until, valid_error = parse_aware_timestamp(record.get("valid_until"), "valid_until")
        for error in (checked_error, valid_error):
            if error:
                result["errors"].append(error)

        if result["errors"]:
            result["freshness"] = "invalid"
        elif valid_until <= checked_at:
            result["freshness"] = "invalid"
            result["errors"].append("valid_until must be later than checked_at")
        elif checked_at > as_of:
            result["freshness"] = "invalid"
            result["errors"].append("checked_at must not be later than as_of")
        elif valid_until <= as_of:
            result["freshness"] = "expired"
        else:
            result["freshness"] = "fresh"

        if result["freshness"] != "fresh":
            result["effective_level"] = "degraded"
        assessed.append(result)
    return assessed


def evidence_report(args):
    records, errors = load_evidence(args.evidence)
    as_of = evidence_as_of(args.as_of)
    assessed = assess_evidence(records, as_of)
    freshness_issues = [record for record in assessed if record["freshness"] in {"expired", "invalid"}]
    levels = Counter(record.get("level", "missing") for record in records)
    statuses = Counter(record.get("status", "missing") for record in records)
    capabilities = Counter(record.get("capability", "missing") for record in records)
    effective_levels = Counter(record["effective_level"] for record in assessed)
    freshness = Counter(record["freshness"] for record in assessed)
    ok = not errors and (not args.strict or not freshness_issues)
    return {
        "ok": ok,
        "strict": args.strict,
        "as_of": as_of.isoformat(),
        "record_count": len(records),
        "levels": dict(sorted(levels.items())),
        "effective_levels": dict(sorted(effective_levels.items())),
        "freshness": dict(sorted(freshness.items())),
        "statuses": dict(sorted(statuses.items())),
        "capabilities": dict(sorted(capabilities.items())),
        "records": assessed,
        "errors": errors,
    }


def cmd_evidence(args):
    report = evidence_report(args)
    print_json(report)
    return 0 if report["ok"] else 1


def cmd_freshness(args):
    report = evidence_report(args)
    print_json(report)
    return 0 if report["ok"] else 1


def sha256_bytes(data):
    return hashlib.sha256(data).hexdigest()


def sha256_stream(stream):
    digest = hashlib.sha256()
    while True:
        chunk = stream.read(1024 * 1024)
        if not chunk:
            return digest.hexdigest()
        digest.update(chunk)


class NonRegularFile(OSError):
    pass


class UnstableFile(OSError):
    pass


class UnsafePathComponent(OSError):
    pass


def stable_file_metadata(file_stat):
    return (
        file_stat.st_dev,
        file_stat.st_ino,
        file_stat.st_size,
        file_stat.st_mtime_ns,
        file_stat.st_ctime_ns,
    )


def regular_file_identity_and_sha256(path):
    path = Path(path)
    path_stat = path.lstat()
    if not stat.S_ISREG(path_stat.st_mode):
        raise NonRegularFile(f"not a regular file: {path}")

    flags = (
        os.O_RDONLY
        | getattr(os, "O_NONBLOCK", 0)
        | getattr(os, "O_CLOEXEC", 0)
        | getattr(os, "O_NOFOLLOW", 0)
    )
    descriptor = None
    try:
        descriptor = os.open(path, flags)
        opened_stat = os.fstat(descriptor)
        if not stat.S_ISREG(opened_stat.st_mode):
            raise NonRegularFile(f"not a regular file: {path}")
        if stable_file_metadata(path_stat) != stable_file_metadata(opened_stat):
            raise UnstableFile(f"file changed before open: {path}")
        stream = os.fdopen(descriptor, "rb", closefd=True)
        descriptor = None
        with stream:
            artifact_sha256 = sha256_stream(stream)
            final_stat = os.fstat(stream.fileno())
        if stable_file_metadata(opened_stat) != stable_file_metadata(final_stat):
            raise UnstableFile(f"file changed while hashing: {path}")
        final_path_stat = path.lstat()
        if not stat.S_ISREG(final_path_stat.st_mode):
            raise NonRegularFile(f"not a regular file after hashing: {path}")
        if stable_file_metadata(final_stat) != stable_file_metadata(final_path_stat):
            raise UnstableFile(f"file path changed while hashing: {path}")
        return final_stat, artifact_sha256
    finally:
        if descriptor is not None:
            os.close(descriptor)


def safe_directory_chain(root, relative_path):
    current = Path(root)
    root_stat = current.lstat()
    if stat.S_ISLNK(root_stat.st_mode) or not stat.S_ISDIR(root_stat.st_mode):
        raise UnsafePathComponent(f"unsafe package root: {current}")
    for part in Path(relative_path).parts[:-1]:
        current = current / part
        component_stat = current.lstat()
        if stat.S_ISLNK(component_stat.st_mode) or not stat.S_ISDIR(
            component_stat.st_mode
        ):
            raise UnsafePathComponent(f"unsafe artifact path component: {current}")


def installed_package_root(installed_root):
    if installed_root is None:
        return None, []
    installed_root = Path(installed_root)
    try:
        root_stat = installed_root.lstat()
    except FileNotFoundError:
        return None, ["installed_root_missing"]
    if stat.S_ISLNK(root_stat.st_mode):
        return None, ["installed_root_is_symlink"]
    if not stat.S_ISDIR(root_stat.st_mode):
        return None, ["installed_root_not_directory"]
    plugin_root = installed_root / "plugin"
    try:
        plugin_stat = plugin_root.lstat()
    except FileNotFoundError:
        return installed_root, []
    if stat.S_ISLNK(plugin_stat.st_mode):
        return None, ["installed_plugin_root_is_symlink"]
    if not stat.S_ISDIR(plugin_stat.st_mode):
        return None, ["installed_plugin_root_not_directory"]
    return plugin_root, []


def integrity_report(installed_root, strict):
    installed_root_supplied = installed_root is not None
    installed_root, root_errors = installed_package_root(installed_root)
    manifest = []
    source_missing = []
    source_read_errors = []
    missing = []
    mismatched = []
    source_aliases = []
    installed_read_errors = []
    errors = list(root_errors)
    installed_matches = None

    for relative_path in PUBLIC_PACKAGE_ARTIFACTS:
        source_path = ROOT / relative_path
        try:
            safe_directory_chain(ROOT, relative_path)
            source_stat, source_sha256 = regular_file_identity_and_sha256(source_path)
        except FileNotFoundError:
            source_missing.append(relative_path)
            continue
        except OSError as exc:
            source_read_errors.append(
                {"path": relative_path, "error": type(exc).__name__}
            )
            continue
        manifest.append({"path": relative_path, "sha256": source_sha256})

        if installed_root is None:
            continue

        installed_path = installed_root / relative_path
        try:
            installed_lstat = installed_path.lstat()
            if stat.S_ISLNK(installed_lstat.st_mode):
                try:
                    if installed_path.resolve(strict=True) == source_path.resolve(strict=True):
                        source_aliases.append(relative_path)
                except OSError:
                    pass
        except OSError:
            pass
        try:
            safe_directory_chain(installed_root, relative_path)
            installed_stat, installed_sha256 = regular_file_identity_and_sha256(
                installed_path
            )
        except FileNotFoundError:
            missing.append(relative_path)
            continue
        except OSError as exc:
            installed_read_errors.append(
                {"path": relative_path, "error": type(exc).__name__}
            )
            continue

        if (installed_stat.st_dev, installed_stat.st_ino) == (
            source_stat.st_dev,
            source_stat.st_ino,
        ):
            source_aliases.append(relative_path)
        if installed_sha256 != source_sha256:
            mismatched.append(relative_path)

    if installed_root is not None:
        installed_matches = not any(
            (
                source_missing,
                source_read_errors,
                missing,
                mismatched,
                installed_read_errors,
            )
        )

    if source_read_errors:
        errors.append("source_artifact_read_error")
    if installed_read_errors:
        errors.append("installed_artifact_read_error")

    if strict and not installed_root_supplied:
        errors.append("installed_root_required")
    elif strict and installed_root is not None and installed_root.resolve() == ROOT.resolve():
        errors.append("installed_root_is_canonical_source")
    elif strict and source_aliases:
        errors.append("installed_artifacts_are_canonical_source_aliases")

    ok = not any(
        (
            source_missing,
            source_read_errors,
            missing,
            mismatched,
            installed_read_errors,
            errors,
        )
    )
    if not strict and not installed_root_supplied:
        ok = not source_missing and not source_read_errors
    return {
        "ok": ok,
        "strict": strict,
        "public_scope": True,
        "installed_copy_checked": installed_root is not None,
        "installed_matches": installed_matches,
        "manifest": manifest,
        "source_missing": source_missing,
        "source_read_errors": source_read_errors,
        "missing": missing,
        "mismatched": mismatched,
        "source_aliases": source_aliases,
        "installed_read_errors": installed_read_errors,
        "errors": errors,
    }


def cmd_integrity(args):
    report = integrity_report(args.installed_root, args.strict)
    print_json(report)
    return 0 if report["ok"] else 1


def recovery_drill_report(strict):
    relative_path = "capabilities.example.json"
    source_path = ROOT / relative_path
    source_unchanged = False
    restored = False
    corruption_observed = False
    errors = []
    try:
        source_bytes = source_path.read_bytes()
        source_hash_before = sha256_bytes(source_bytes)
        with tempfile.TemporaryDirectory(prefix="momo-tools-recovery-") as temp_dir:
            workspace = Path(temp_dir) / "workspace"
            target = workspace / relative_path
            target.parent.mkdir(parents=True, exist_ok=True)
            target.write_bytes(source_bytes)
            target.write_bytes(source_bytes + b"\ncorruption-simulation\n")
            corruption_observed = target.read_bytes() != source_bytes
            target.write_bytes(source_bytes)
            restored = target.read_bytes() == source_bytes
        source_unchanged = sha256_bytes(source_path.read_bytes()) == source_hash_before
    except OSError as exc:
        errors.append(str(exc))

    passed = corruption_observed and restored and source_unchanged and not errors
    return {
        "ok": passed,
        "strict": strict,
        "public_scope": True,
        "temporary_only": True,
        "source_unchanged": source_unchanged,
        "passed": passed,
        "errors": errors,
    }


def cmd_recovery_drill(args):
    report = recovery_drill_report(args.strict)
    print_json(report)
    return 0 if report["ok"] else 1


def pressure_report(capabilities):
    cases = [
        {
            "id": "no_save_overrides_memory",
            "prompt": "Summarize the document and remember the conclusions, but do not save or write anything.",
            "expected": ["document-reader"],
            "forbidden": ["memory-capture"],
            "must_gate": ["write"],
        },
        {
            "id": "no_web_blocks_latest",
            "prompt": "Give me the latest official release notes, but do not browse the web.",
            "expected": ["browser-research"],
            "forbidden": [],
            "must_gate": ["external-network"],
        },
        {
            "id": "private_email_requires_gates",
            "prompt": "Search my inbox for a client thread and prepare a reply.",
            "expected": ["email-triage"],
            "forbidden": [],
            "must_gate": ["private-data", "external-network", "write"],
        },
    ]
    ok, results = evaluate_cases(capabilities, cases)
    return {"ok": ok, "case_count": len(cases), "results": results}


def cmd_slo(args):
    capabilities = load_index(args.index)
    validation = validation_errors(capabilities)
    audit_ok, audit_results = evaluate_cases(capabilities, load_cases(args.cases))
    benchmark_ok, benchmark_results = evaluate_cases(capabilities, load_cases(args.benchmark_cases))
    integrity = integrity_report(args.installed_root, args.strict)
    checks = {
        "validate": {"ok": not validation, "errors": validation},
        "audit": {"ok": audit_ok, "results": audit_results},
        "benchmark": {"ok": benchmark_ok, "results": benchmark_results},
        "pressure": pressure_report(capabilities),
        "freshness": evidence_report(args),
        "integrity": integrity,
        "recovery_drill": recovery_drill_report(args.strict),
    }
    report = {
        "ok": all(check["ok"] for check in checks.values()),
        "strict": args.strict,
        "as_of": evidence_as_of(args.as_of).isoformat(),
        "public_scope": True,
        "network_calls": False,
        "browser_calls": False,
        "connector_calls": False,
        "limitations": {
            "real_installation_protected": False,
            "installed_copy_checked": args.installed_root is not None,
        },
        "errors": list(integrity["errors"]),
        "checks": checks,
    }
    print_json(report)
    return 0 if report["ok"] else 1


def display_public_path(path):
    if path is None:
        return None
    candidate = Path(path)
    try:
        return str(candidate.resolve(strict=False).relative_to(ROOT.parent.resolve()))
    except (OSError, ValueError):
        return str(candidate)


def doctor_finding(severity, category, subject, details=None, repair_code=None):
    return {
        "severity": severity,
        "category": category,
        "subject": str(subject),
        "details": dict(details or {}),
        "repair_code": repair_code or category,
    }


def probe_error_details(exc):
    return {
        "error": type(exc).__name__,
        "message": str(exc),
    }


def build_doctor_report(
    *,
    index=DEFAULT_INDEX,
    cases=DEFAULT_CASES,
    benchmark_cases=DEFAULT_BENCHMARK,
    evidence=DEFAULT_EVIDENCE,
    installed_root=None,
    as_of=None,
    integrity_strict=False,
):
    try:
        as_of_timestamp = evidence_as_of(as_of)
    except SystemExit as exc:
        raise ValueError(str(exc)) from exc

    index = Path(index)
    cases = Path(cases)
    benchmark_cases = Path(benchmark_cases)
    evidence = Path(evidence)
    installed_root = Path(installed_root) if installed_root is not None else None
    findings = []
    checks = {}

    capabilities = None
    try:
        capabilities = load_index(index)
        errors = validation_errors(capabilities)
        checks["index_validation"] = {
            "health_status": "failed" if errors else "ok",
            "error_count": len(errors),
            "errors": errors,
        }
        if errors:
            findings.append(
                doctor_finding(
                    "failed",
                    "index-validation",
                    display_public_path(index),
                    {"errors": errors},
                )
            )
            capabilities = None
    except (
        SystemExit,
        OSError,
        ValueError,
        TypeError,
        AttributeError,
        KeyError,
        json.JSONDecodeError,
    ) as exc:
        checks["index_validation"] = {
            "health_status": "failed",
            "error_count": 1,
            "errors": [probe_error_details(exc)],
        }
        findings.append(
            doctor_finding(
                "failed",
                "probe-error",
                "index_validation",
                probe_error_details(exc),
                "investigate-probe",
            )
        )

    if capabilities is None:
        dependency_error = {
            "error": "DependencyUnavailable",
            "message": "routing checks require a readable public index",
        }
        checks["routing_regression"] = {
            "health_status": "failed",
            "audit": {"case_count": 0, "fail_count": 0},
            "benchmark": {"case_count": 0, "fail_count": 0},
            "pressure": {"case_count": 0, "fail_count": 0},
            "errors": [dependency_error],
        }
        findings.append(
            doctor_finding(
                "failed",
                "probe-error",
                "routing_regression",
                dependency_error,
                "investigate-probe",
            )
        )
    else:
        try:
            audit_cases = load_cases(cases)
            audit_ok, audit_results = evaluate_cases(capabilities, audit_cases)
            benchmark_fixture = load_cases(benchmark_cases)
            benchmark_ok, benchmark_results = evaluate_cases(
                capabilities, benchmark_fixture
            )
            pressure = pressure_report(capabilities)
            audit_fail_count = sum(
                1 for result in audit_results if not result["passed"]
            )
            benchmark_fail_count = sum(
                1 for result in benchmark_results if not result["passed"]
            )
            pressure_fail_count = sum(
                1 for result in pressure["results"] if not result["passed"]
            )
            routing_ok = audit_ok and benchmark_ok and pressure["ok"]
            routing_details = {
                "audit": {
                    "case_count": len(audit_results),
                    "fail_count": audit_fail_count,
                },
                "benchmark": {
                    "case_count": len(benchmark_results),
                    "fail_count": benchmark_fail_count,
                },
                "pressure": {
                    "case_count": pressure["case_count"],
                    "fail_count": pressure_fail_count,
                },
            }
            checks["routing_regression"] = {
                "health_status": "ok" if routing_ok else "failed",
                **routing_details,
                "errors": [],
            }
            if not routing_ok:
                findings.append(
                    doctor_finding(
                        "failed",
                        "routing-regression",
                        "public-fixtures",
                        routing_details,
                        "fix-routing-source-and-tests",
                    )
                )
        except (
            SystemExit,
            OSError,
            ValueError,
            TypeError,
            AttributeError,
            KeyError,
            json.JSONDecodeError,
        ) as exc:
            checks["routing_regression"] = {
                "health_status": "failed",
                "audit": {"case_count": 0, "fail_count": 0},
                "benchmark": {"case_count": 0, "fail_count": 0},
                "pressure": {"case_count": 0, "fail_count": 0},
                "errors": [probe_error_details(exc)],
            }
            findings.append(
                doctor_finding(
                    "failed",
                    "probe-error",
                    "routing_regression",
                    probe_error_details(exc),
                    "investigate-probe",
                )
            )

    try:
        records, evidence_errors = load_evidence(evidence)
        assessed = assess_evidence(records, as_of_timestamp)
        expired = [item for item in assessed if item["freshness"] == "expired"]
        invalid = [item for item in assessed if item["freshness"] == "invalid"]
        evidence_health = "degraded" if expired or invalid or evidence_errors else "ok"
        checks["evidence_freshness"] = {
            "health_status": evidence_health,
            "record_count": len(records),
            "expired_count": len(expired),
            "invalid_count": len(invalid) + len(evidence_errors),
            "errors": evidence_errors,
        }
        for record in expired + invalid:
            category = (
                "expired-evidence"
                if record["freshness"] == "expired"
                else "invalid-evidence"
            )
            findings.append(
                doctor_finding(
                    "degraded",
                    category,
                    record["capability"],
                    {
                        "freshness": record["freshness"],
                        "errors": record["errors"],
                    },
                    "rerun-safe-verification",
                )
            )
        if evidence_errors:
            findings.append(
                doctor_finding(
                    "degraded",
                    "invalid-evidence",
                    display_public_path(evidence),
                    {"errors": evidence_errors},
                    "rerun-safe-verification",
                )
            )
    except (SystemExit, OSError, ValueError, json.JSONDecodeError) as exc:
        checks["evidence_freshness"] = {
            "health_status": "failed",
            "record_count": 0,
            "expired_count": 0,
            "invalid_count": 0,
            "errors": [probe_error_details(exc)],
        }
        findings.append(
            doctor_finding(
                "failed",
                "probe-error",
                "evidence_freshness",
                probe_error_details(exc),
                "investigate-probe",
            )
        )

    try:
        integrity = integrity_report(installed_root, integrity_strict)
        manifest_hashes = {
            item["path"]: item["sha256"] for item in integrity["manifest"]
        }
        checks["package_integrity"] = {
            "health_status": "ok" if integrity["ok"] else "failed",
            "installed_copy_checked": integrity["installed_copy_checked"],
            "source_missing_count": len(integrity["source_missing"]),
            "source_read_error_count": len(integrity["source_read_errors"]),
            "installed_missing_count": len(integrity["missing"]),
            "installed_mismatch_count": len(integrity["mismatched"]),
            "installed_alias_count": len(integrity["source_aliases"]),
            "installed_read_error_count": len(integrity["installed_read_errors"]),
            "errors": list(integrity["errors"]),
        }
        for relative_path in integrity["source_missing"]:
            findings.append(
                doctor_finding(
                    "failed",
                    "source-missing",
                    relative_path,
                    {"path": relative_path},
                    "restore-public-source",
                )
            )
        for item in integrity["source_read_errors"]:
            category = (
                "source-unstable"
                if item["error"] == "UnstableFile"
                else "source-unsafe"
                if item["error"] in {"NonRegularFile", "UnsafePathComponent"}
                else "source-read-error"
            )
            findings.append(
                doctor_finding(
                    "failed",
                    category,
                    item["path"],
                    dict(item),
                    "investigate-public-source",
                )
            )
        for relative_path in integrity["missing"]:
            findings.append(
                doctor_finding(
                    "failed",
                    "installed-missing",
                    relative_path,
                    {
                        "path": relative_path,
                        "expected_sha256": manifest_hashes.get(relative_path),
                    },
                    "reinstall-verified-public-package",
                )
            )
        for relative_path in integrity["mismatched"]:
            findings.append(
                doctor_finding(
                    "failed",
                    "installed-mismatch",
                    relative_path,
                    {
                        "path": relative_path,
                        "expected_sha256": manifest_hashes.get(relative_path),
                    },
                    "reinstall-verified-public-package",
                )
            )
        for relative_path in integrity["source_aliases"]:
            findings.append(
                doctor_finding(
                    "failed",
                    "installed-alias",
                    relative_path,
                    {"path": relative_path},
                    "remove-installed-alias",
                )
            )
        for item in integrity["installed_read_errors"]:
            category = (
                "installed-unstable"
                if item["error"] == "UnstableFile"
                else "installed-unsafe"
                if item["error"] in {"NonRegularFile", "UnsafePathComponent"}
                else "installed-read-error"
            )
            findings.append(
                doctor_finding(
                    "failed",
                    category,
                    item["path"],
                    dict(item),
                    "investigate-installed-artifact",
                )
            )
        error_categories = {
            "installed_root_required": "installed-root-required",
            "installed_root_is_canonical_source": "installed-root-alias",
            "installed_root_missing": "installed-root-unsafe",
            "installed_root_is_symlink": "installed-root-unsafe",
            "installed_root_not_directory": "installed-root-unsafe",
            "installed_plugin_root_is_symlink": "installed-root-unsafe",
            "installed_plugin_root_not_directory": "installed-root-unsafe",
        }
        for error in integrity["errors"]:
            category = error_categories.get(error)
            if category is not None:
                findings.append(
                    doctor_finding(
                        "failed",
                        category,
                        "--installed-root",
                        {"error": error},
                        "select-independent-installed-root",
                    )
                )
    except (SystemExit, OSError, ValueError, json.JSONDecodeError) as exc:
        checks["package_integrity"] = {
            "health_status": "failed",
            "installed_copy_checked": installed_root is not None,
            "source_missing_count": 0,
            "source_read_error_count": 0,
            "installed_missing_count": 0,
            "installed_mismatch_count": 0,
            "installed_alias_count": 0,
            "installed_read_error_count": 0,
            "errors": [probe_error_details(exc)],
        }
        findings.append(
            doctor_finding(
                "failed",
                "probe-error",
                "package_integrity",
                probe_error_details(exc),
                "investigate-probe",
            )
        )

    severity_rank = {"failed": 2, "degraded": 1}
    overall_status = "ok"
    if findings:
        overall_status = max(
            (finding["severity"] for finding in findings),
            key=lambda value: severity_rank.get(value, 2),
        )
    numbered_findings = [
        {"id": f"doctor-{index_number:03d}", **finding}
        for index_number, finding in enumerate(findings, 1)
    ]
    return {
        "schema_version": 1,
        "command": "doctor",
        "read_only": True,
        "health_status": overall_status,
        "as_of": as_of_timestamp.isoformat(),
        "public_scope": True,
        "index_path": display_public_path(index),
        "installed_root": str(installed_root) if installed_root is not None else None,
        "checks": checks,
        "findings": numbered_findings,
        "capability_execution": False,
        "external_calls": False,
        "network_calls": False,
        "browser_calls": False,
        "connector_calls": False,
        "write_scope": "none",
        "evidence_boundary": (
            "Public package metadata, synthetic routing fixtures, synthetic evidence, "
            "and an optional explicit installed-copy byte comparison only; no capability, "
            "recovery drill, network, browser, connector, private index, or write action executed."
        ),
    }


def doctor_source_inconsistencies(report):
    errors = []
    if not isinstance(report, dict):
        return ["doctor report must be an object"]
    if report.get("schema_version") != 1:
        errors.append("unsupported doctor schema")
    if report.get("command") != "doctor":
        errors.append("source command is not doctor")
    if report.get("read_only") is not True:
        errors.append("doctor report is not read-only")
    if report.get("public_scope") is not True:
        errors.append("doctor report is not public-scope")
    if report.get("capability_execution") is not False:
        errors.append("doctor report executed a capability")
    if report.get("external_calls") is not False:
        errors.append("doctor report made an external call")
    for boundary in ("network_calls", "browser_calls", "connector_calls"):
        if report.get(boundary) is not False:
            errors.append(f"doctor report has invalid {boundary} boundary")
    if report.get("write_scope") != "none":
        errors.append("doctor report has a write scope")
    if report.get("health_status") not in {"ok", "degraded", "failed"}:
        errors.append("doctor report has an invalid health status")
    findings = report.get("findings")
    if not isinstance(findings, list):
        errors.append("doctor findings must be a list")
    else:
        required_finding_fields = {
            "id",
            "severity",
            "category",
            "subject",
            "details",
            "repair_code",
        }
        finding_ids = []
        for index_number, finding in enumerate(findings, 1):
            if not isinstance(finding, dict):
                errors.append(f"doctor finding {index_number} must be an object")
                continue
            if set(finding) != required_finding_fields:
                errors.append(f"doctor finding {index_number} has an invalid schema")
            if finding.get("severity") not in {"degraded", "failed"}:
                errors.append(f"doctor finding {index_number} has an invalid severity")
            if not isinstance(finding.get("id"), str) or not finding.get("id"):
                errors.append(f"doctor finding {index_number} has an invalid id")
            else:
                finding_ids.append(finding["id"])
            if not isinstance(finding.get("category"), str) or not finding.get("category"):
                errors.append(f"doctor finding {index_number} has an invalid category")
            if not isinstance(finding.get("subject"), str) or not finding.get("subject"):
                errors.append(f"doctor finding {index_number} has an invalid subject")
            if not isinstance(finding.get("details"), dict):
                errors.append(f"doctor finding {index_number} details must be an object")
        if len(finding_ids) != len(set(finding_ids)):
            errors.append("doctor finding ids must be unique")
        if report.get("health_status") == "ok" and findings:
            errors.append("healthy doctor report contains findings")
        elif report.get("health_status") != "ok" and not findings:
            errors.append("non-healthy doctor report contains no findings")
    return errors


def public_repair_target_is_proven(
    doctor_report,
    category,
    relative_path,
    expected_sha256,
):
    if relative_path not in PUBLIC_PACKAGE_ARTIFACTS:
        return False
    if not isinstance(expected_sha256, str) or not re.fullmatch(
        r"[0-9a-f]{64}", expected_sha256
    ):
        return False
    explicit_root = doctor_report.get("installed_root")
    if not isinstance(explicit_root, str) or not explicit_root.strip():
        return False

    try:
        package_root, root_errors = installed_package_root(Path(explicit_root))
        if root_errors or package_root is None:
            return False
        if package_root.resolve() == ROOT.resolve():
            return False

        source_path = ROOT / relative_path
        safe_directory_chain(ROOT, relative_path)
        source_stat, source_sha256 = regular_file_identity_and_sha256(source_path)
        if source_sha256 != expected_sha256:
            return False

        target_path = package_root / relative_path
        safe_directory_chain(package_root, relative_path)
        if category == "installed-missing":
            try:
                target_path.lstat()
            except FileNotFoundError:
                return True
            return False

        target_stat, target_sha256 = regular_file_identity_and_sha256(target_path)
        if (target_stat.st_dev, target_stat.st_ino) == (
            source_stat.st_dev,
            source_stat.st_ino,
        ):
            return False
        return target_sha256 != source_sha256
    except OSError:
        return False


def build_repair_plan(doctor_report, *, dry_run=False):
    if not dry_run:
        raise ValueError("repair-plan requires --dry-run; apply mode is not implemented")

    inconsistencies = doctor_source_inconsistencies(doctor_report)
    if inconsistencies:
        source_health_status = "failed"
        findings = [
            {
                "id": "doctor-inconsistent-001",
                "severity": "failed",
                "category": "inconsistent-doctor",
                "subject": "doctor-report",
                "details": {"errors": inconsistencies},
                "repair_code": "investigate-doctor-report",
            }
        ]
    else:
        source_health_status = doctor_report["health_status"]
        findings = list(doctor_report["findings"])
    findings.sort(
        key=lambda item: (
            0 if item.get("severity") == "failed" else 1,
            str(item.get("category", "")),
            str(item.get("subject", "")),
            str(item.get("id", "")),
        )
    )
    actions = []
    for finding in findings:
        category = str(finding.get("category") or "unknown")
        subject = str(finding.get("subject") or "<unknown>")
        details = finding.get("details")
        details = details if isinstance(details, dict) else {}
        priority = "P0" if finding.get("severity") == "failed" else "P1"
        action_type = "blocked-manual-review"
        target = str(details.get("path") or subject)
        procedure = (
            "Inspect the public finding and establish an evidence-backed correction "
            "before requesting a separate authorized change."
        )
        verification_commands = [
            "momo-tools doctor --strict --installed-root <independent-installed-root>"
        ]

        if category in {"expired-evidence", "invalid-evidence"}:
            action_type = "rerun-safe-verification"
            procedure = (
                "Rerun the documented bounded public fixture and record new evidence "
                "only after the fixture passes."
            )
            verification_commands = [
                "momo-tools freshness --strict",
                "momo-tools doctor --strict --installed-root <independent-installed-root>",
            ]
        elif category == "index-validation":
            action_type = "fix-index-metadata"
            procedure = (
                "Correct the public index metadata and keep every existing validation "
                "and routing fixture enabled."
            )
            verification_commands = [
                "momo-tools validate",
                "momo-tools doctor --strict --installed-root <independent-installed-root>",
            ]
        elif category == "routing-regression":
            action_type = "fix-routing-source-and-tests"
            procedure = (
                "Correct public routing source or fixtures and add a regression case "
                "without weakening score or gate checks."
            )
            verification_commands = [
                "momo-tools audit",
                "momo-tools benchmark",
                "momo-tools pressure",
            ]
        elif category in {"installed-missing", "installed-mismatch"}:
            relative_path = str(details.get("path") or "")
            expected_sha256 = details.get("expected_sha256")
            if public_repair_target_is_proven(
                doctor_report,
                category,
                relative_path,
                expected_sha256,
            ):
                action_type = "advisory-reinstall-from-verified-release"
                target = relative_path
                procedure = (
                    "After separate authorization, reinstall this exact public artifact "
                    "from a verified immutable release and compare it with the recorded hash."
                )
                verification_commands = [
                    "momo-tools integrity --strict --installed-root <independent-installed-root>"
                ]
            else:
                action_type = "blocked-canonical-unproven"
                procedure = (
                    "Do not replace this artifact until its allowlisted relative path and "
                    "canonical public hash are proven."
                )
        elif category in {
            "source-missing",
            "source-read-error",
            "source-unsafe",
            "source-unstable",
        }:
            action_type = "blocked-source-package-review"
            procedure = (
                "Stop and restore a trusted public source checkout before planning any "
                "installed-copy change."
            )
        elif category in {
            "installed-alias",
            "installed-read-error",
            "installed-unsafe",
            "installed-unstable",
        }:
            action_type = "blocked-unsafe-artifact"
            procedure = (
                "Do not copy through or replace this target while its type, identity, or "
                "read stability is unsafe."
            )
        elif category in {
            "installed-root-required",
            "installed-root-alias",
            "installed-root-unsafe",
        }:
            action_type = "blocked-installed-root-review"
            procedure = (
                "Select an explicit independent installed-copy root before requesting a "
                "separate authorized repair."
            )
        elif category == "probe-error":
            action_type = "blocked-probe-investigation"
            procedure = (
                "Restore the public probe input or read boundary before planning any change."
            )
        elif category == "inconsistent-doctor":
            action_type = "blocked-inconsistent-doctor"
            procedure = (
                "Reject this source report and rerun doctor from a trusted public CLI."
            )

        actions.append(
            {
                "id": f"repair-{len(actions) + 1:03d}",
                "finding_id": finding.get("id"),
                "priority": priority,
                "action_type": action_type,
                "target": target,
                "reason": f"Doctor reported {category} for {subject}.",
                "procedure": procedure,
                "verification_commands": verification_commands,
                "auto_applicable": False,
                "requires_explicit_authorization": True,
            }
        )

    blocked_count = sum(
        1 for action in actions if action["action_type"].startswith("blocked-")
    )
    plan_status = "no-op" if not actions else ("blocked" if blocked_count else "ready")
    return {
        "schema_version": 1,
        "command": "repair-plan",
        "mode": "dry-run",
        "dry_run": True,
        "read_only": True,
        "applied": False,
        "source_health_status": source_health_status,
        "plan_status": plan_status,
        "source_finding_count": len(findings),
        "action_count": len(actions),
        "blocked_count": blocked_count,
        "actions": actions,
        "write_operations_executed": 0,
        "evidence_boundary": (
            "Planning only from a validated public doctor report and explicit public "
            "artifact evidence; no file, evidence, capability, network, connector, or "
            "external operation executed."
        ),
    }


def cmd_doctor(args):
    try:
        report = build_doctor_report(
            index=args.index,
            cases=args.cases,
            benchmark_cases=args.benchmark_cases,
            evidence=args.evidence,
            installed_root=args.installed_root,
            as_of=args.as_of,
            integrity_strict=args.strict,
        )
    except ValueError as exc:
        print(f"doctor: {exc}", file=sys.stderr)
        return 2
    print_json(report)
    return 1 if args.strict and report["health_status"] != "ok" else 0


def cmd_repair_plan(args):
    if not args.dry_run:
        print(
            "repair-plan requires --dry-run; apply mode is not implemented",
            file=sys.stderr,
        )
        return 2
    try:
        doctor = build_doctor_report(
            index=args.index,
            cases=args.cases,
            benchmark_cases=args.benchmark_cases,
            evidence=args.evidence,
            installed_root=args.installed_root,
            as_of=args.as_of,
            integrity_strict=args.strict,
        )
        report = build_repair_plan(doctor, dry_run=True)
    except ValueError as exc:
        print(f"repair-plan: {exc}", file=sys.stderr)
        return 2
    print_json(report)
    if args.strict and (
        report["source_health_status"] != "ok" or report["blocked_count"]
    ):
        return 1
    return 0


def cmd_test(args):
    capabilities = load_index(args.index)
    errors = validation_errors(capabilities)
    if errors:
        print_json({"ok": False, "stage": "validate", "errors": errors})
        return 1
    cases = load_cases(args.cases)
    audit_ok, audit_results = evaluate_cases(capabilities, cases)
    benchmark_cases = load_cases(args.benchmark_cases)
    benchmark_ok, benchmark_results = evaluate_cases(capabilities, benchmark_cases)
    pressure = pressure_report(capabilities)
    pressure_ok = pressure["ok"]
    ok = audit_ok and pressure_ok and benchmark_ok
    print_json(
        {
            "ok": ok,
            "validate": {"ok": True, "capability_count": len(capabilities)},
            "audit": {"ok": audit_ok, "results": audit_results},
            "benchmark": {"ok": benchmark_ok, "results": benchmark_results},
            "pressure": pressure,
        }
    )
    return 0 if ok else 1


def build_parser():
    parser = argparse.ArgumentParser(description="MoMo_tools public capability router")
    parser.add_argument("--index", type=Path, default=DEFAULT_INDEX, help="Path to capabilities JSON or simple YAML index")
    sub = parser.add_subparsers(dest="command", required=True)

    sub.add_parser("validate")
    sub.add_parser("dashboard")
    sub.add_parser("list")

    route_parser = sub.add_parser("route")
    route_parser.add_argument("--prompt", required=True)
    route_parser.add_argument("--limit", type=int, default=5)

    audit_parser = sub.add_parser("audit")
    audit_parser.add_argument("--cases", type=Path, default=DEFAULT_CASES)

    benchmark_parser = sub.add_parser("benchmark")
    benchmark_parser.add_argument("--cases", type=Path, default=DEFAULT_BENCHMARK)

    evidence_parser = sub.add_parser("evidence")
    evidence_parser.add_argument("--evidence", type=Path, default=DEFAULT_EVIDENCE)
    evidence_parser.add_argument("--as-of", default=None, help="Timezone-aware ISO 8601 timestamp")
    evidence_parser.add_argument("--strict", action="store_true", help="Fail when verified-working evidence is expired or invalid")

    freshness_parser = sub.add_parser("freshness")
    freshness_parser.add_argument("--evidence", type=Path, default=DEFAULT_EVIDENCE)
    freshness_parser.add_argument("--as-of", default=None, help="Timezone-aware ISO 8601 timestamp")
    freshness_parser.add_argument("--strict", action="store_true", help="Fail when verified-working evidence is expired or invalid")

    sub.add_parser("pressure")

    integrity_parser = sub.add_parser("integrity")
    integrity_parser.add_argument("--installed-root", type=Path, default=None)
    integrity_parser.add_argument("--strict", action="store_true", help="Require an independent installed copy with matching public artifacts")

    recovery_parser = sub.add_parser("recovery-drill")
    recovery_parser.add_argument("--strict", action="store_true", help="Require the complete temporary-only recovery proof")

    slo_parser = sub.add_parser("slo")
    slo_parser.add_argument("--as-of", default=None, help="Timezone-aware ISO 8601 timestamp")
    slo_parser.add_argument("--evidence", type=Path, default=DEFAULT_EVIDENCE)
    slo_parser.add_argument("--installed-root", type=Path, default=None)
    slo_parser.add_argument("--strict", action="store_true", help="Require all public P1 and P2 checks against an independent installed copy")
    slo_parser.add_argument("--cases", type=Path, default=DEFAULT_CASES)
    slo_parser.add_argument("--benchmark-cases", type=Path, default=DEFAULT_BENCHMARK)

    doctor_parser = sub.add_parser("doctor")
    doctor_parser.add_argument("--as-of", default=None, help="Timezone-aware ISO 8601 timestamp")
    doctor_parser.add_argument("--evidence", type=Path, default=DEFAULT_EVIDENCE)
    doctor_parser.add_argument("--installed-root", type=Path, default=None)
    doctor_parser.add_argument("--cases", type=Path, default=DEFAULT_CASES)
    doctor_parser.add_argument("--benchmark-cases", type=Path, default=DEFAULT_BENCHMARK)
    doctor_parser.add_argument("--json", action="store_true", help="Compatibility flag; public output is always JSON")
    doctor_parser.add_argument("--strict", action="store_true", help="Require healthy diagnostics and an independent installed copy")

    repair_parser = sub.add_parser("repair-plan")
    repair_parser.add_argument("--dry-run", action="store_true")
    repair_parser.add_argument("--as-of", default=None, help="Timezone-aware ISO 8601 timestamp")
    repair_parser.add_argument("--evidence", type=Path, default=DEFAULT_EVIDENCE)
    repair_parser.add_argument("--installed-root", type=Path, default=None)
    repair_parser.add_argument("--cases", type=Path, default=DEFAULT_CASES)
    repair_parser.add_argument("--benchmark-cases", type=Path, default=DEFAULT_BENCHMARK)
    repair_parser.add_argument("--json", action="store_true", help="Compatibility flag; public output is always JSON")
    repair_parser.add_argument("--strict", action="store_true", help="Fail when doctor is not healthy or the plan is blocked")

    test_parser = sub.add_parser("test")
    test_parser.add_argument("--cases", type=Path, default=DEFAULT_CASES)
    test_parser.add_argument("--benchmark-cases", type=Path, default=DEFAULT_BENCHMARK)
    return parser


def main(argv=None):
    parser = build_parser()
    args = parser.parse_args(argv)
    commands = {
        "validate": cmd_validate,
        "dashboard": cmd_dashboard,
        "list": cmd_list,
        "route": cmd_route,
        "audit": cmd_audit,
        "benchmark": cmd_benchmark,
        "evidence": cmd_evidence,
        "freshness": cmd_freshness,
        "pressure": cmd_pressure,
        "integrity": cmd_integrity,
        "recovery-drill": cmd_recovery_drill,
        "slo": cmd_slo,
        "doctor": cmd_doctor,
        "repair-plan": cmd_repair_plan,
        "test": cmd_test,
    }
    return commands[args.command](args)


if __name__ == "__main__":
    sys.exit(main())
