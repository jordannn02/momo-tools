    "canonical_for",
    "workflow_shape",
}

VERIFICATION_LEVELS = {"visible", "executed", "verified-working"}
EVIDENCE_REQUIRED_FIELDS = {
    "capability",
    "level",
    "status",
    "checked_at",
    "command",
    "evidence_ref",
    "risk_boundary",
}
VERIFIED_WORKING_FRESHNESS_FIELDS = {"checked_at", "valid_until"}

RISK_HINTS = {
    "write": [
        "write",
